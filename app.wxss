/**
 * AI 冰箱食材管理助手 - 全局样式
 */

/* ===== CSS 变量（Light 主题） ===== */
page {
  --color-primary: #4CAF50;
  --color-primary-light: #81C784;
  --color-primary-dark: #388E3C;
  --color-primary-bg: rgba(76, 175, 80, 0.08);

  --color-danger: #F44336;
  --color-danger-light: #EF9A9A;
  --color-warning: #FF9800;
  --color-warning-light: #FFE0B2;
  --color-success: #4CAF50;
  --color-info: #2196F3;
  --color-info-light: #BBDEFB;

  --bg-page: #f5f7fa;
  --bg-card: #ffffff;
  --bg-input: #f5f5f5;
  --bg-section: #ffffff;

  --text-primary: #1a1a1a;
  --text-secondary: #666666;
  --text-hint: #999999;
  --text-inverse: #ffffff;

  --border-color: #eeeeee;
  --shadow-card: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  --shadow-float: 0 4rpx 24rpx rgba(0, 0, 0, 0.12);

  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-full: 999rpx;

  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  background-color: var(--bg-page);
  line-height: 1.6;
}

/* ===== Dark 主题 ===== */
page.dark {
  --color-primary-bg: rgba(76, 175, 80, 0.15);

  --bg-page: #121212;
  --bg-card: #1e1e1e;
  --bg-input: #2a2a2a;
  --bg-section: #1e1e1e;

  --text-primary: #e0e0e0;
  --text-secondary: #aaaaaa;
  --text-hint: #777777;

  --border-color: #333333;
  --shadow-card: 0 2rpx 12rpx rgba(0, 0, 0, 0.3);
  --shadow-float: 0 4rpx 24rpx rgba(0, 0, 0, 0.5);
}

/* ===== 通用工具类 ===== */
.container {
  padding: var(--spacing-md);
  min-height: 100vh;
  box-sizing: border-box;
}

.card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-card);
}

.card-sm {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-sm);
  box-shadow: var(--shadow-card);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--spacing-md);
}

.section-subtitle {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-bottom: var(--spacing-sm);
}

/* Flex 布局 */
.flex-row { display: flex; flex-direction: row; align-items: center; }
.flex-col { display: flex; flex-direction: column; }
.flex-between { justify-content: space-between; }
.flex-around { justify-content: space-around; }
.flex-center { justify-content: center; align-items: center; }
.flex-wrap { flex-wrap: wrap; }
.flex-1 { flex: 1; }

/* 文本 */
.text-center { text-align: center; }
.text-right { text-align: right; }
.text-primary { color: var(--color-primary); }
.text-danger { color: var(--color-danger); }
.text-warning { color: var(--color-warning); }
.text-secondary { color: var(--text-secondary); }
.text-hint { color: var(--text-hint); }
.text-bold { font-weight: 600; }
.text-sm { font-size: 24rpx; }
.text-md { font-size: 28rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }
.text-2xl { font-size: 44rpx; }

/* 按钮 */
.btn-primary {
  background: linear-gradient(135deg, var(--color-primary-light), var(--color-primary));
  color: #fff;
  border: none;
  border-radius: var(--radius-full);
  padding: 20rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.btn-primary::after { border: none; }

.btn-outline {
  background: transparent;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-full);
  padding: 18rpx 48rpx;
  font-size: 30rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.btn-outline::after { border: none; }

.btn-danger {
  background: linear-gradient(135deg, #EF5350, #F44336);
  color: #fff;
  border: none;
  border-radius: var(--radius-full);
  padding: 20rpx 48rpx;
  font-size: 30rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.btn-danger::after { border: none; }

.btn-sm {
  padding: 12rpx 28rpx;
  font-size: 24rpx;
}

/* 标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
  font-weight: 500;
}

.tag-primary { background: var(--color-primary-bg); color: var(--color-primary); }
.tag-danger { background: rgba(244, 67, 54, 0.1); color: var(--color-danger); }
.tag-warning { background: rgba(255, 152, 0, 0.1); color: var(--color-warning); }
.tag-info { background: rgba(33, 150, 243, 0.1); color: var(--color-info); }
.tag-normal { background: rgba(76, 175, 80, 0.1); color: #4CAF50; }

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--border-color);
  margin: var(--spacing-md) 0;
}

/* 间距 */
.mt-xs { margin-top: var(--spacing-xs); }
.mt-sm { margin-top: var(--spacing-sm); }
.mt-md { margin-top: var(--spacing-md); }
.mt-lg { margin-top: var(--spacing-lg); }
.mb-xs { margin-bottom: var(--spacing-xs); }
.mb-sm { margin-bottom: var(--spacing-sm); }
.mb-md { margin-bottom: var(--spacing-md); }
.mb-lg { margin-bottom: var(--spacing-lg); }
.p-sm { padding: var(--spacing-sm); }
.p-md { padding: var(--spacing-md); }
.p-lg { padding: var(--spacing-lg); }

/* 头像/圆形 */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-primary-bg);
}

.avatar-lg {
  width: 120rpx;
  height: 120rpx;
}

/* 渐变背景 */
.gradient-primary {
  background: linear-gradient(135deg, #66BB6A, #43A047);
}

.gradient-warm {
  background: linear-gradient(135deg, #FFB74D, #FF9800);
}

.gradient-cool {
  background: linear-gradient(135deg, #64B5F6, #1E88E5);
}

/* 安全区域底部 */
.safe-bottom {
  padding-bottom: calc(env(safe-area-inset-bottom) + 20rpx);
}

/* 隐藏滚动条 */
::-webkit-scrollbar { display: none; }
