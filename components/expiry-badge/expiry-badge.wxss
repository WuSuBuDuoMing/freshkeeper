.expiry-badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 500;
}
.badge-normal { background: rgba(76, 175, 80, 0.1); color: #4CAF50; }
.badge-expiring { background: rgba(255, 152, 0, 0.1); color: #FF9800; }
.badge-expired { background: rgba(244, 67, 54, 0.1); color: #F44336; }
.badge-used { background: rgba(153, 153, 153, 0.1); color: #999; }
