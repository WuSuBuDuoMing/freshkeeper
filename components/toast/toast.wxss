.toast-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; display: flex; align-items: center; justify-content: center; z-index: 9999; pointer-events: none; }
.toast-content { display: flex; align-items: center; gap: 12rpx; padding: 24rpx 32rpx; border-radius: 16rpx; background: rgba(0,0,0,0.75); color: #fff; font-size: 28rpx; max-width: 80%; }
.toast-icon { font-size: 32rpx; }
.toast-success { background: rgba(76,175,80,0.9); }
.toast-error { background: rgba(244,67,54,0.9); }
.toast-warning { background: rgba(255,152,0,0.9); }
