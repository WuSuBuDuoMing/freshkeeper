.empty-state {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 80rpx 40rpx;
}
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-title { font-size: 32rpx; color: var(--text-secondary, #666); font-weight: 500; }
.empty-desc { font-size: 26rpx; color: var(--text-hint, #999); margin-top: 12rpx; text-align: center; }
