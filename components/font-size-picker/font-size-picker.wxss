/**
 * 字体大小选择组件样式
 */

.font-size-picker {
  padding: 24rpx 0;
}

.picker-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 24rpx;
  font-weight: 500;
}

.picker-options {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.option-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  background-color: #f5f5f5;
  border: 4rpx solid transparent;
  transition: all 0.2s ease;
}

.option-item.active {
  background-color: #e8f5e9;
  border-color: #4caf50;
  color: #4caf50;
}

.option-item:active {
  transform: scale(0.95);
}

.option-preview {
  font-size: 28rpx;
  color: #333;
  line-height: 1.2;
}

.option-item.active .option-preview {
  color: #4caf50;
}

.option-label {
  font-size: 22rpx;
  color: #666;
  margin-top: 8rpx;
}

.option-item.active .option-label {
  color: #4caf50;
  font-weight: 500;
}
