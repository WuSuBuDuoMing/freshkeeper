.recognizer-item {
  display: flex; align-items: center; gap: 16rpx; padding: 20rpx;
  background: #fff; border-radius: 12rpx; margin-bottom: 12rpx;
  border: 2rpx solid #eee; transition: all 0.2s;
}
.recognizer-item.selected { border-color: #4CAF50; background: rgba(76,175,80,0.04); }
.checkbox { font-size: 36rpx; color: #4CAF50; flex-shrink: 0; }
.item-emoji { font-size: 40rpx; flex-shrink: 0; }
.item-info { flex: 1; min-width: 0; }
.item-name {
  font-size: 28rpx; font-weight: 600; color: #1a1a1a;
  background: transparent; border-bottom: 1rpx solid #eee; padding: 4rpx 0;
}
.item-meta { display: flex; align-items: center; gap: 12rpx; margin-top: 8rpx; }
.qty-input {
  width: 80rpx; text-align: center; font-size: 24rpx; background: #f5f5f5;
  border-radius: 8rpx; padding: 6rpx 0;
}
.item-unit { font-size: 24rpx; color: #666; }
.item-confidence { font-size: 22rpx; color: #999; margin-left: auto; }
.category-tag {
  font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 999rpx;
  background: rgba(76,175,80,0.1); color: #4CAF50; flex-shrink: 0;
}
