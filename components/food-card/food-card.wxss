.food-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: var(--bg-card, #fff);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s;
}

.card-hover {
  transform: scale(0.98);
  opacity: 0.9;
}

.food-card.compact {
  padding: 16rpx;
  margin-bottom: 8rpx;
}

.food-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(76, 175, 80, 0.08);
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.emoji {
  font-size: 36rpx;
}

.food-info {
  flex: 1;
  min-width: 0;
}

.food-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.food-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary, #1a1a1a);
}

.food-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.meta-text {
  font-size: 24rpx;
  color: var(--text-secondary, #666);
}

.food-notes {
  margin-top: 6rpx;
}

.notes-text {
  font-size: 22rpx;
  color: var(--text-hint, #999);
}

.food-actions {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.action-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.04);
}

.action-btn text {
  font-size: 24rpx;
}
