.pull-refresh { transition: transform 0.3s ease; position: relative; }
.refresh-indicator { display: flex; flex-direction: column; align-items: center; padding: 16rpx 0; }
.refresh-icon { font-size: 40rpx; transition: transform 0.3s ease; }
.refresh-icon.spinning { animation: spin 0.8s linear infinite; }
.refresh-text { font-size: 24rpx; color: #999; margin-top: 8rpx; }
@keyframes spin { to { transform: rotate(360deg); } }
