.stat-card {
  display: flex; align-items: center; background: var(--bg-card, #fff);
  border-radius: 16rpx; padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.stat-icon {
  width: 72rpx; height: 72rpx; display: flex; align-items: center; justify-content: center;
  border-radius: 16rpx; font-size: 32rpx; margin-right: 16rpx; flex-shrink: 0;
}
.stat-content { flex: 1; }
.stat-value-row { display: flex; align-items: baseline; gap: 4rpx; }
.stat-value { font-size: 40rpx; font-weight: 700; }
.stat-unit { font-size: 24rpx; color: var(--text-secondary, #666); }
.stat-title { font-size: 24rpx; color: var(--text-secondary, #666); margin-top: 4rpx; }
