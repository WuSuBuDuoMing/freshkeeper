/**
 * 营养进度条组件样式
 */

.nutrition-bar {
  padding: 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* ===== 主条目（热量） ===== */

.bar-item--main {
  margin-bottom: 32rpx;
}

.bar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.bar-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.bar-value {
  font-size: 24rpx;
  color: #666666;
}

/* ===== 进度条轨道 ===== */

.track {
  width: 100%;
  height: 20rpx;
  background: #f0f0f0;
  border-radius: 10rpx;
  overflow: hidden;
}

.track--small {
  height: 12rpx;
  border-radius: 6rpx;
}

/* ===== 进度条填充 ===== */

.fill {
  height: 100%;
  border-radius: inherit;
  transition: width 0.6s ease;
  min-width: 0;
}

.fill--calories {
  background: linear-gradient(90deg, #FF6B35, #FF8E53);
}

.fill--protein {
  background: linear-gradient(90deg, #4ECDC4, #44B5AB);
}

.fill--fat {
  background: linear-gradient(90deg, #FFE66D, #F0D043);
}

.fill--carbs {
  background: linear-gradient(90deg, #95E1D3, #78CEBF);
}

/* ===== 百分比 ===== */

.bar-percent {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #999999;
  margin-top: 8rpx;
}

/* ===== 三列分组 ===== */

.bar-group {
  display: flex;
  gap: 24rpx;
}

.bar-item--small {
  flex: 1;
}

.bar-label--small {
  font-size: 22rpx;
  font-weight: 500;
}

.bar-value--small {
  display: block;
  font-size: 20rpx;
  color: #999999;
  margin-top: 8rpx;
  text-align: center;
}
