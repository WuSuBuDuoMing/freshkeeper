<view class="container">
  <view wx:if="{{status === 'idle'}}" class="idle-state">
    <text class="big-icon">📷</text>
    <text class="scan-title">拍照识别食材</text>
    <text class="scan-desc">拍一张冰箱里的食材照片，AI 自动识别并添加</text>
    <button class="btn-primary scan-btn" bindtap="onTakePhoto">拍照识别</button>
    <button class="btn-outline scan-btn" bindtap="onFromAlbum">从相册选择</button>
  </view>

  <view wx:if="{{status === 'recognizing'}}">
    <image wx:if="{{imagePath}}" src="{{imagePath}}" mode="aspectFill" class="preview-image" />
    <view class="analyzing">
      <view class="loading-spinner"></view>
      <text>AI 正在识别食材...</text>
    </view>
  </view>

  <view wx:if="{{status === 'done'}}">
    <image wx:if="{{imagePath}}" src="{{imagePath}}" mode="aspectFill" class="preview-image-small" />
    <text class="results-title">识别到 {{results.length}} 种食材</text>
    <food-recognizer wx:for="{{results}}" wx:key="name" item="{{item}}" index="{{index}}"
      bind:toggle="onToggleSelect" bind:namechange="onNameInput" bind:quantitychange="onQuantityChange" />
    <view class="bottom-bar">
      <button class="btn-outline" bindtap="onRetry">重新拍照</button>
      <button class="btn-primary" bindtap="onAddAll">添加到冰箱</button>
    </view>
  </view>

  <view wx:if="{{status === 'error'}}">
    <text class="big-icon">😔</text>
    <text>识别失败，请重试</text>
    <button class="btn-primary" bindtap="onRetry">重新识别</button>
  </view>
</view>
