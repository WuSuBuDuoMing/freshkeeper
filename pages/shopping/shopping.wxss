.summary-bar { display: flex; align-items: center; justify-content: space-around; padding: 32rpx; }
.summary-item { display: flex; flex-direction: column; align-items: center; }
.summary-value { font-size: 36rpx; font-weight: 700; color: var(--color-primary, #4CAF50); }
.summary-label { font-size: 24rpx; color: var(--text-hint, #999); margin-top: 4rpx; }
.summary-divider { width: 1rpx; height: 48rpx; background: var(--border-color, #eee); }

.tab-bar { display: flex; gap: 8rpx; margin-bottom: 16rpx; }
.tab {
  flex: 1; text-align: center; padding: 16rpx 0; border-radius: 12rpx;
  font-size: 28rpx; color: var(--text-secondary, #666); background: var(--bg-card, #fff);
}
.tab.active { background: var(--color-primary, #4CAF50); color: #fff; font-weight: 600; }

.add-form-btn {
  display: flex; align-items: center; gap: 12rpx; padding: 20rpx 24rpx;
  background: var(--bg-card, #fff); border-radius: 12rpx; margin-bottom: 16rpx;
  font-size: 28rpx; color: var(--color-primary, #4CAF50);
}
.add-icon { font-size: 32rpx; }

.add-form { padding: 24rpx; margin-bottom: 16rpx; }
.form-input {
  background: var(--bg-input, #f5f5f5); border-radius: 8rpx; padding: 16rpx;
  font-size: 28rpx; margin-bottom: 16rpx;
}
.form-row { display: flex; gap: 16rpx; align-items: center; }
.form-input-small {
  flex: 1; background: var(--bg-input, #f5f5f5); border-radius: 8rpx; padding: 14rpx 16rpx;
  font-size: 26rpx; text-align: center;
}

.group-section { margin-bottom: 24rpx; }
.group-title {
  font-size: 26rpx; font-weight: 600; color: var(--text-secondary, #666);
  padding: 12rpx 0; border-bottom: 1rpx solid var(--border-color, #eee);
  margin-bottom: 8rpx; display: block;
}
.clear-btn {
  text-align: center; padding: 16rpx; margin-bottom: 16rpx;
  font-size: 26rpx; color: var(--color-danger, #F44336);
}
