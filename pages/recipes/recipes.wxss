.refresh-bar { display: flex; gap: 16rpx; margin-bottom: 16rpx; }
.refresh-btn, .weekly-menu-btn {
  flex: 1; display: flex; align-items: center; justify-content: center;
  padding: 16rpx; background: var(--bg-card, #fff); border-radius: 12rpx;
  font-size: 26rpx; color: var(--color-primary, #4CAF50);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center;
  z-index: 999; padding: 40rpx;
}
.modal-content {
  background: var(--bg-card, #fff); border-radius: 24rpx; width: 100%;
  max-height: 80vh; overflow-y: auto;
}
.modal-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 24rpx 32rpx; border-bottom: 1rpx solid var(--border-color, #eee);
}
.modal-title { font-size: 32rpx; font-weight: 700; color: var(--text-primary, #1a1a1a); }
.modal-close { font-size: 32rpx; color: var(--text-hint, #999); padding: 8rpx; }
.modal-body { padding: 24rpx 32rpx; }
.detail-row { display: flex; justify-content: space-between; padding: 12rpx 0; }
.detail-label { font-size: 26rpx; color: var(--text-secondary, #666); }
.detail-value { font-size: 26rpx; color: var(--text-primary, #1a1a1a); font-weight: 500; }
.detail-section { margin-top: 20rpx; }
.detail-section-title { font-size: 28rpx; font-weight: 600; color: var(--text-primary, #1a1a1a); margin-bottom: 12rpx; display: block; }
.tag-list { display: flex; flex-wrap: wrap; gap: 8rpx; }
.steps-list { display: flex; flex-direction: column; gap: 12rpx; }
.step-item { display: flex; align-items: center; gap: 12rpx; }
.step-num {
  width: 40rpx; height: 40rpx; display: flex; align-items: center; justify-content: center;
  background: rgba(76,175,80,0.1); color: #4CAF50; border-radius: 50%;
  font-size: 24rpx; font-weight: 600; flex-shrink: 0;
}
.step-text { font-size: 26rpx; color: var(--text-primary, #1a1a1a); }
.reason-text { font-size: 26rpx; color: var(--color-primary, #4CAF50); }
.modal-footer { padding: 16rpx 32rpx 32rpx; }
.modal-footer .btn-primary { width: 100%; }
