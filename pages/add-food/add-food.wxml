<view class="container">
  <!-- 食材名称 -->
  <view class="form-group">
    <text class="form-label">食材名称 *</text>
    <view class="form-input-wrap {{errors.name ? 'error' : ''}}">
      <input class="form-input" placeholder="请输入食材名称" value="{{form.name}}" bindinput="onInputName" />
    </view>
    <text class="form-error" wx:if="{{errors.name}}">{{errors.name}}</text>
  </view>

  <!-- 分类选择 -->
  <view class="form-group">
    <text class="form-label">分类</text>
    <picker mode="selector" range="{{categories}}" range-key="name" value="{{categories.length > 0 ? 0 : 0}}" bindchange="onCategoryChange">
      <view class="picker-value">
        <text>{{form.category}}</text>
        <text class="picker-arrow">▼</text>
      </view>
    </picker>
  </view>

  <!-- 数量 -->
  <view class="form-group">
    <text class="form-label">数量</text>
    <view class="quantity-control">
      <view class="qty-btn" bindtap="onQuantityMinus">−</view>
      <input class="qty-input" type="number" value="{{form.quantity}}" bindinput="onQuantityChange" />
      <view class="qty-btn" bindtap="onQuantityPlus">＋</view>
      <picker class="unit-picker" mode="selector" range="{{units}}" bindchange="onUnitChange">
        <view class="unit-btn">{{form.unit}} ▼</view>
      </picker>
    </view>
  </view>

  <!-- 存放位置 -->
  <view class="form-group">
    <text class="form-label">存放位置</text>
    <picker mode="selector" range="{{storageAreas}}" range-key="key" value="0" bindchange="onStorageAreaChange">
      <view class="picker-value">
        <text>{{form.storageArea}}</text>
        <text class="picker-arrow">▼</text>
      </view>
    </picker>
  </view>

  <!-- 购买日期 -->
  <view class="form-group">
    <text class="form-label">购买日期</text>
    <picker mode="date" value="{{form.purchaseDate}}" bindchange="onPurchaseDateChange">
      <view class="picker-value">
        <text>{{form.purchaseDate || '选择日期'}}</text>
        <text class="picker-arrow">📅</text>
      </view>
    </picker>
  </view>

  <!-- 过期日期 -->
  <view class="form-group">
    <text class="form-label">过期日期 *</text>
    <picker mode="date" value="{{form.expiryDate}}" bindchange="onExpiryDateChange">
      <view class="picker-value {{errors.expiryDate ? 'error' : ''}}">
        <text>{{form.expiryDate || '选择日期'}}</text>
        <text class="picker-arrow">📅</text>
      </view>
    </picker>
    <text class="form-error" wx:if="{{errors.expiryDate}}">{{errors.expiryDate}}</text>
  </view>

  <!-- 备注 -->
  <view class="form-group">
    <text class="form-label">备注</text>
    <textarea class="form-textarea" placeholder="添加备注信息..." value="{{form.notes}}" bindinput="onNotesInput" maxlength="100" />
  </view>

  <!-- 提交按钮 -->
  <button class="btn-primary submit-btn" bindtap="onSubmit">
    {{isEdit ? '保存修改' : '添加食材'}}
  </button>

  <view style="height: 60rpx;"></view>
</view>
