.form-group { margin-bottom: 28rpx; }
.form-label { font-size: 28rpx; font-weight: 600; color: var(--text-primary, #1a1a1a); margin-bottom: 12rpx; display: block; }
.form-input-wrap {
  background: var(--bg-input, #f5f5f5); border-radius: 12rpx; padding: 20rpx 24rpx;
  border: 2rpx solid transparent;
}
.form-input-wrap.error { border-color: var(--color-danger, #F44336); }
.form-input { font-size: 28rpx; color: var(--text-primary, #1a1a1a); width: 100%; }
.form-error { font-size: 24rpx; color: var(--color-danger, #F44336); margin-top: 8rpx; display: block; }
.form-textarea {
  background: var(--bg-input, #f5f5f5); border-radius: 12rpx; padding: 20rpx 24rpx;
  font-size: 28rpx; width: 100%; min-height: 120rpx; box-sizing: border-box;
}
.picker-value {
  background: var(--bg-input, #f5f5f5); border-radius: 12rpx; padding: 20rpx 24rpx;
  display: flex; justify-content: space-between; align-items: center;
  font-size: 28rpx; color: var(--text-primary, #1a1a1a);
}
.picker-value.error { border: 2rpx solid var(--color-danger, #F44336); }
.picker-arrow { font-size: 22rpx; color: var(--text-hint, #999); }
.quantity-control {
  display: flex; align-items: center; gap: 16rpx;
}
.qty-btn {
  width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center;
  background: var(--bg-input, #f5f5f5); border-radius: 12rpx; font-size: 32rpx;
  color: var(--color-primary, #4CAF50); font-weight: 600;
}
.qty-input {
  width: 100rpx; height: 64rpx; text-align: center; font-size: 28rpx;
  background: var(--bg-input, #f5f5f5); border-radius: 12rpx;
}
.unit-picker { margin-left: auto; }
.unit-btn {
  padding: 16rpx 24rpx; background: var(--bg-input, #f5f5f5); border-radius: 12rpx;
  font-size: 26rpx; color: var(--text-secondary, #666);
}
.submit-btn { width: 100%; margin-top: 32rpx; }
