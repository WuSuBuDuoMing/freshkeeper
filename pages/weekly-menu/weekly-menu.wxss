.btn-add-all { width: 100%; margin-bottom: 24rpx; }
.day-card { padding: 24rpx; }
.day-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.day-info { display: flex; align-items: center; gap: 12rpx; }
.day-info.today { background: rgba(76,175,80,0.08); padding: 8rpx 16rpx; border-radius: 12rpx; }
.day-weekday { font-size: 30rpx; font-weight: 700; color: var(--text-primary, #1a1a1a); }
.day-date { font-size: 26rpx; color: var(--text-secondary, #666); }
.today-badge {
  font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 999rpx;
  background: var(--color-primary, #4CAF50); color: #fff;
}
.day-actions { display: flex; gap: 12rpx; }
.day-btn {
  width: 48rpx; height: 48rpx; display: flex; align-items: center; justify-content: center;
  background: rgba(0,0,0,0.04); border-radius: 50%; font-size: 24rpx;
}
.meals { display: flex; flex-direction: column; gap: 12rpx; }
.meal-item {
  display: flex; align-items: center; gap: 12rpx; padding: 12rpx 16rpx;
  background: var(--bg-input, #f5f5f5); border-radius: 12rpx;
}
.meal-label { font-size: 24rpx; color: var(--text-secondary, #666); min-width: 100rpx; }
.meal-name { flex: 1; font-size: 26rpx; color: var(--text-primary, #1a1a1a); }
.meal-emoji { font-size: 28rpx; }
