.profile-header { display: flex; align-items: center; gap: 24rpx; padding: 32rpx; }
.avatar-text { font-size: 48rpx; }
.profile-info { flex: 1; }
.profile-name { font-size: 36rpx; font-weight: 700; color: var(--text-primary, #1a1a1a); display: block; }
.profile-desc { font-size: 26rpx; color: var(--text-secondary, #666); margin-top: 4rpx; display: block; }

.stats-row {
  display: flex; justify-content: space-around; padding: 24rpx;
  background: var(--bg-card, #fff); border-radius: 16rpx; margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.stat-mini { display: flex; flex-direction: column; align-items: center; }
.stat-mini-value { font-size: 36rpx; font-weight: 700; color: #4CAF50; }
.stat-mini-label { font-size: 22rpx; color: #999; margin-top: 4rpx; }

.menu-section {
  background: #fff; border-radius: 16rpx; margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); overflow: hidden;
}
.menu-item {
  display: flex; align-items: center; padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #eee;
}
.menu-item:last-child { border-bottom: none; }
.menu-icon { font-size: 32rpx; margin-right: 20rpx; }
.menu-name { flex: 1; font-size: 28rpx; color: #1a1a1a; }
.menu-arrow { font-size: 32rpx; color: #999; }
.menu-switch { transform: scale(0.8); }

.footer { text-align: center; padding: 40rpx 0; }
.footer-text { font-size: 22rpx; color: #999; display: block; margin-bottom: 4rpx; }
